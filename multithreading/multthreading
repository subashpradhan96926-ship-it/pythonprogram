import threading
import time

class BankAccount:
    def __init__(self, balance):
        self.balance = balance
        self.lock = threading.Lock()
    def withdraw(self, amount):
        with self.lock:  # Ensure only one thread modifies balance at a time
            print(f"\n{threading.current_thread().name} is trying to withdraw ${amount}")
            if self.balance >= amount:
                print(f"{threading.current_thread().name} - Balance before withdrawal: ${self.balance}")
                time.sleep(1)  # Simulate delay
                self.balance -= amount
                print(f"{threading.current_thread().name} - Withdrawal successful. New balance: ${self.balance}")
            else:
                print(f"{threading.current_thread().name} - Not enough balance. Current balance: ${self.balance}")

# Create shared account object
account = BankAccount(100)

# Create threads simulating ATM and Mobile App
t1 = threading.Thread(target=account.withdraw, args=(70,), name="ATM")
t2 = threading.Thread(target=account.withdraw, args=(50,), name="MobileApp")
t1.start()
t2.start()

t1.join()
t2.join()
print(f"\nFinal account balance: ${account.balance}")




import threading
import time

# Shared resource and condition object
condition = threading.Condition()
data_ready = False
data = None

# Producer Thread
def producer():
    global data_ready, data
    with condition:
        print("Producer: preparing data...")
        time.sleep(2)
        data = "Hello from producer"
        data_ready = True
        print("Producer: data ready, notifying consumer...")
        condition.notify()  # Notify the waiting thread

# Consumer Thread
def consumer():
    global data_ready
    with condition:
        print("Consumer: waiting for data...")
        while not data_ready:
            condition.wait()  # Wait until notified
        print("Consumer: data received:", data)

# Start threads
t1 = threading.Thread(target=consumer)
t2 = threading.Thread(target=producer)

t1.start()